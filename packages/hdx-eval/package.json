{
  "name": "@hyperdx/hdx-eval",
  "version": "0.2.2",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.16.0"
  },
  "bin": "./dist/cli.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/*"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.47",
    "@clickhouse/client": "1.23.0-head.fae5998.1",
    "ai": "^6.0.116",
    "commander": "^12.1.0",
    "ms": "^2.1.3",
    "zod": "3.25"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@types/jest": "^29.5.14",
    "@types/ms": "^0.7.31",
    "@types/node": "^22.15.18",
    "jest": "^30.2.0",
    "rimraf": "^4.4.1",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 ./scripts/env.sh tsx src/cli.ts",
    "lint": "npx eslint . --ext .ts --max-warnings 3",
    "lint:fix": "npx eslint . --ext .ts --fix",
    "ci:lint": "yarn lint && yarn tsc --noEmit",
    "ci:unit": "jest --ci --coverage --forceExit",
    "dev:unit": "jest --watch",
    "viewer": "node scripts/viewer/server.js"
  }
}
