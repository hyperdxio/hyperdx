exports[`renderBuilderConfigAsSqlTemplate macro-izes the series-limit CTE and inlines its LIMIT 1`] = `
"WITH
  \`__hdx_series_limit\` AS (
    SELECT
      \`group\`
    FROM
      (
        SELECT
          tuple(ServiceName) AS \`group\`,
          count() AS \`__hdx_series_rank\`
        FROM
