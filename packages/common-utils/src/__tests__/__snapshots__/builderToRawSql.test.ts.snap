`;

exports[`renderBuilderConfigAsSqlTemplate series-level WHERE (aggCondition → -If combinators) tightens the two argument lists of a parametric combinator 1`] = `
"SELECT
  quantileIf(0.95)(
    toFloat64OrDefault(toString(value)),
    (ServiceName ILIKE '%api%')
    AND toFloat64OrDefault(toString(value)) IS NOT NULL
  ),
  ServiceName,
  $__timeInterval(timestamp) AS \`__hdx_time_bucket\`
FROM
  $__sourceTable
WHERE
  (
    timestamp >= $__fromTime_ms
    AND timestamp <= $__toTime_ms
  )
  AND ((ServiceName ILIKE '%api%'))
  AND $__filters
GROUP BY
  ServiceName,
  $__timeInterval(timestamp) AS \`__hdx_time_bucket\`
ORDER BY
  $__timeInterval(timestamp) AS \`__hdx_time_bucket\`"
`;
