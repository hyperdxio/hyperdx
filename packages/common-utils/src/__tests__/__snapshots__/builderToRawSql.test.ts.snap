exports[`renderBuilderConfigAsSqlTemplate series-level WHERE (aggCondition → -If combinators) renders one -If per series and OR-pushes conditions when every series is filtered 1`] = `
"SELECT
  countIf((ServiceName ILIKE '%api%')),
  avgIf(
    toFloat64OrDefault(toString(value)),
    (ServiceName ILIKE '%web%')
    AND toFloat64OrDefault(toString(value)) IS NOT NULL
  ),
  ServiceName,
  $__timeInterval(timestamp) AS \`__hdx_time_bucket\`
FROM
  $__sourceTable
WHERE
  (
    timestamp >= $__fromTime_ms
    AND timestamp <= $__toTime_ms
  )
  AND (
    (ServiceName ILIKE '%api%')
    OR (ServiceName ILIKE '%web%')
  )
  AND $__filters
GROUP BY
  ServiceName,
  $__timeInterval(timestamp) AS \`__hdx_time_bucket\`
ORDER BY
  $__timeInterval(timestamp) AS \`__hdx_time_bucket\`"
`;

