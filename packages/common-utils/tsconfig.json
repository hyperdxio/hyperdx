{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declarationMap": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    },
    "declaration": true,
    "isolatedModules": true,
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "src/clickhouse/**",
    "src/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.int.test.ts",
    "dist"
  ]
}
