# Berg API dev configuration.
#
# This file is loaded by `nx run @berg/api:dev` via dotenv-expand. Values
# here are NOT inherited from the root .env — edit this file (not root)
# when changing API behaviour.

NODE_ENV=development
BERG_LOG_LEVEL=debug

# Ports — explicit, no shell-env interpolation.
PORT=8000
BERG_API_PORT=8000
BERG_APP_PORT=8080
FRONTEND_URL=http://localhost:8080

# Express session
EXPRESS_SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# MongoDB
MONGO_URI=mongodb://localhost:27017/berg

# Other runtime
NODE_OPTIONS="--max-http-header-size=131072"
ENABLE_SWAGGER=true
USAGE_STATS_ENABLED=false

# AWS Athena (Berg). Required at runtime; CI/test installs may leave them
# blank — the lazy resolver in config.ts only enforces them outside CI.
ATHENA_REGION=<aws-region>                     # e.g. us-east-1
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_LOCATION=s3://<query-results-bucket>/
ATHENA_SYNC_TIMEOUT_MS=30000
ATHENA_RESULT_REUSE_TTL_MIN=60

# Glue catalog scoping. For S3 Tables, use:
#   <aws-account-id>:s3tablescatalog/<catalog-name>
# For the default Glue Data Catalog, leave unset.
GLUE_CATALOG_ID=<aws-account-id>:s3tablescatalog/<catalog-name>
GLUE_DATABASES=<comma-separated-database-names>  # e.g. db1,db2

# AWS auth — uncomment ONE method. In EKS, IRSA replaces all of these.
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional dev API key (legacy)
BERG_API_KEY="dev-api-key"
