# Berg App dev configuration.
#
# Loaded by `nx run @berg/app:dev` via dotenv-cli. Edit this file (not
# root .env) when changing App behaviour.

NODE_ENV=development

# Ports — App binds PORT, calls API at SERVER_URL. Must match the API's
# packages/api/.env.development settings.
PORT=8080
SERVER_URL=http://localhost:8000

NODE_OPTIONS="--max-http-header-size=131072"
NEXT_PUBLIC_HYPERDX_BASE_PATH=
NEXT_PUBLIC_IS_DASHBOARD_LINKING_ENABLED=true

# Optional dev ingestion key (legacy)
HYPERDX_API_KEY="super-secure-ingestion-api-key"
