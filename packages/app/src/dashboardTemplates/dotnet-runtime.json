            "aggFn": "sum",
            "valueExpression": "",
            "metricName": "dotnet.gc.pause.time",
            "metricType": "sum"
          }
        ],
        "where": "",
        "whereLanguage": "sql",
        "numberFormat": {
          "output": "number",
          "mantissa": 3,
          "thousandSeparated": true
