      }
    },
    {
      "id": "ebe6dc",
      "x": 12,
      "y": 24,
      "w": 12,
      "h": 7,
      "config": {
        "name": "ThreadPool Throughput & Lock Contention",
        "source": "Metrics",
        "displayType": "line",
        "granularity": "auto",
        "alignDateRangeToGranularity": true,
        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "",
            "metricName": "dotnet.thread_pool.work_item.count",
            "metricType": "sum",
            "alias": "work items"
          },
          {
            "aggFn": "sum",
            "valueExpression": "",
            "metricName": "dotnet.monitor.lock_contentions",
            "metricType": "sum",
            "alias": "contentions"
          }
        ],
        "where": "",
        "whereLanguage": "sql"
      }
    }
  ],
  "filters": [
    {
      "id": "svc-filter-001",
      "type": "QUERY_EXPRESSION",
      "name": "ServiceName",
      "expression": "ServiceName",
      "source": "Metrics",
      "sourceMetricType": "sum",
      "where": "ResourceAttributes['telemetry.sdk.language'] = 'dotnet'",
      "whereLanguage": "sql"
    }
  ]
}
