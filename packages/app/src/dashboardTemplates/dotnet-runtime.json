        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "",
            "metricName": "dotnet.exceptions",
            "metricType": "sum"
          }
        ],
        "where": "",
        "whereLanguage": "sql",
        "numberFormat": {
          "output": "number",
          "mantissa": 0,
          "thousandSeparated": true
        }
      }
    },
