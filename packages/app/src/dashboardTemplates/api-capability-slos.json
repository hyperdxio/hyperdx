{
  "version": "0.1.0",
  "name": "API Capability SLOs",
  "description": "Availability (success/total ratio) and latency SLIs for instrumented HyperDX API capabilities, grouped by service. Built on hyperdx.operation.requests and hyperdx.operation.duration_ms. SLO targets are not configured — use these panels to establish baselines before setting objectives.",
  "tags": ["HyperDX API", "SLO", "Instrumentation"],
  "containers": [
    { "id": "overview", "title": "Overview", "collapsed": false },
    { "id": "ai-assistant", "title": "AI Assistant", "collapsed": false },
    {
      "id": "clickhouse-proxy",
      "title": "ClickHouse Proxy",
      "collapsed": false,
      "tabs": [
        { "id": "connection-test", "title": "Connection Test" },
        { "id": "query", "title": "Query Proxy" }
      ]
    },
    {
      "id": "alert-evaluation",
      "title": "Alert Evaluation",
      "collapsed": false
    },
    { "id": "alert-query", "title": "Alert Data Fetch", "collapsed": false }
  ],
  "tiles": [
    {
      "id": "ov001a",
      "containerId": "overview",
      "x": 0,
      "y": 0,
      "w": 24,
      "h": 8,
      "config": {
        "name": "Availability by Service & Capability",
        "source": "Metrics",
        "displayType": "line",
        "granularity": "auto",
        "alignDateRangeToGranularity": true,
        "seriesReturnType": "ratio",
        "select": [
          {
            "aggFn": "sum",
            "aggCondition": "Attributes['outcome'] = 'success'",
            "aggConditionLanguage": "sql",
            "valueExpression": "Value",
            "alias": "Success",
            "metricType": "sum",
            "metricName": "hyperdx.operation.requests"
          },
          {
            "aggFn": "sum",
            "aggCondition": "",
            "aggConditionLanguage": "sql",
            "valueExpression": "Value",
            "alias": "Total",
            "metricType": "sum",
            "metricName": "hyperdx.operation.requests"
          }
        ],
        "where": "",
        "whereLanguage": "sql",
        "groupBy": "ResourceAttributes['service.name'], Attributes['operation']",
        "numberFormat": { "output": "percent" }
      }
    },
